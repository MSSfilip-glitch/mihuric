---
import BaseLayout from '@/layouts/BaseLayout.astro';
import aboveHarbor from '@/assets/design/home-assets/above-harbor.jpg';
import teamPortrait from '@/assets/design/home-assets/team-portrait.jpg';
import teamBriefing from '@/assets/design/home-assets/team-briefing.jpg';
---

<BaseLayout
  title="About — Diving Center Mihurić"
  description="Place-first bio, the crew this season, how we actually run a day on the water — since 1995 from Selce harbour."
  active="about"
>
  <div class="page-wrap">
    <div class="breadcrumbs">
      <a href="/">Home</a><span class="sep">/</span>
      <span>About</span>
    </div>
  </div>

  <section class="about-hero">
    <div class="page-wrap">
      <div class="kicker">About · Selce · since 1995</div>
      <h1>Awesome diving experiences and <em>diver education</em> since 1995.</h1>
      <p class="lede">
        <strong>Ever since we've first opened our doors, we've been committed to providing quality diver training according to the PADI program,</strong> as well as introducing divers to our chunk of the underwater world. Throughout the years, our educational offer has expanded — we've grown into a PADI 5 Star IDC Resort, and we also offer technical diving courses.
      </p>

      <div class="identity-strip">
        <div>
          <div class="num">1995</div>
          <div class="label">Running since</div>
          <div class="sub">Recreational PADI training from the start.</div>
        </div>
        <div>
          <div class="num">30<em>+</em></div>
          <div class="label">Dive locations</div>
          <div class="sub">Reefs, shipwrecks, caves — still looking for more.</div>
        </div>
        <div>
          <div class="num">5<em>★</em></div>
          <div class="label">PADI IDC Resort</div>
          <div class="sub">The top tier of PADI centers — IDC &amp; tec included.</div>
        </div>
        <div>
          <div class="num">30<em>m</em></div>
          <div class="label">Water transparency</div>
          <div class="sub">On a sunny day. Source: our weather page.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt sec-place">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow"><span class="num">01</span> The place</div>
          <h2>Selce, <em>on the Kvarner coast.</em></h2>
        </div>
        <p class="intro">
          Our diving center is in Selce, on the coast. The house reef is right in front of the shop; our speedboat <em>Triton</em> takes divers to around 30 sites in the area. Night dives run a few times a week, mostly on the house reef.
        </p>
      </div>

      <div class="place-wrap">
        <figure class="wide-image">
          <img src={aboveHarbor.src} alt="Selce from above." />
          <div class="caption">Selce · placeholder image</div>
        </figure>

        <article class="place-panel">
          <h3>The shop</h3>
          <p class="pronunciation">Lorem ipsum · placeholder</p>
          <p>
            Lorem ipsum dolor sit amet — a short paragraph about the shop itself (building, classroom, rental wall, compressor) goes here once the owner confirms details.
          </p>
          <div class="specs">
            <div><div class="spec-label">Address</div><div class="spec-value">Šetalište Ivana<br />Jeličića bb, Selce</div></div>
            <div><div class="spec-label">Email</div><div class="spec-value">info@mihuric.hr</div></div>
            <div><div class="spec-label">Phone</div><div class="spec-value">+385 51 765 462</div></div>
            <div><div class="spec-label">Hours</div><div class="spec-value">Lorem ipsum</div></div>
          </div>
        </article>

        <article class="place-panel">
          <h3>The boat — <em class="boat-name">Triton</em></h3>
          <p class="pronunciation">our speedboat</p>
          <p>
            We organise dives at around 30 locations. <em>Triton</em> goes out two times a day, in the morning and in the afternoon. The location is decided in advance, but we also take divers' suggestions and weather conditions into consideration.
          </p>
          <div class="specs">
            <div><div class="spec-label">Type</div><div class="spec-value">Speedboat</div></div>
            <div><div class="spec-label">Trips per day</div><div class="spec-value">2 · AM &amp; PM</div></div>
            <div><div class="spec-label">Season</div><div class="spec-value">Lorem ipsum</div></div>
            <div><div class="spec-label">Capacity</div><div class="spec-value">Lorem ipsum</div></div>
          </div>
        </article>

        <article class="place-panel">
          <h3>The house reef</h3>
          <p class="pronunciation">right in front of the shop</p>
          <p>
            Ideal for novice as well as experienced divers. The reef features a tribute to Neptune, smaller wrecks, a 2 m tall anchor and the usual Adriatic cast — fish, octopuses, slugs, sea horses.
          </p>
          <div class="specs">
            <div><div class="spec-label">Entry</div><div class="spec-value">Shore</div></div>
            <div><div class="spec-label">Min depth</div><div class="spec-value">2 m</div></div>
            <div><div class="spec-label">Max depth</div><div class="spec-value">35 m</div></div>
            <div><div class="spec-label">Certification</div><div class="spec-value">OWD</div></div>
          </div>
        </article>

        <article class="place-panel">
          <h3>The wider area</h3>
          <p class="pronunciation">30 sites in the Kvarner</p>
          <p>
            Shipwrecks, reefs and caves spread across the Kvarner. Our favourite spots offer guests the chance to get to know the local flora and fauna and discover the stories of our shipwrecks.
          </p>
          <div class="specs">
            <div><div class="spec-label">Sites offered</div><div class="spec-value">30 (and counting)</div></div>
            <div><div class="spec-label">Types</div><div class="spec-value">Wrecks · reefs · caves</div></div>
            <div><div class="spec-label">Deepest</div><div class="spec-value">Lorem ipsum</div></div>
            <div><div class="spec-label">Season</div><div class="spec-value">Lorem ipsum</div></div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section dark sec-philosophy">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow"><span class="num">02</span> How we work</div>
          <h2>Friendly, <em>not a production line.</em></h2>
        </div>
        <p class="intro">
          Drawn from our original "Our story" page — four themes that, between them, sum up how we think about running the shop.
        </p>
      </div>

      <div class="credo">
        <blockquote class="credo-quote">
          Lorem ipsum dolor sit amet — a pull quote from the owner belongs here. We'll fill this in with a real line once we have one.
          <cite>— Placeholder</cite>
        </blockquote>

        <div class="principles">
          <div class="principle">
            <div class="p-num">01</div>
            <div>
              <h4>Motivated, passionate instructors.</h4>
              <p>Our instructors and dive guides are motivated professionals with a passion for their work. Beyond being professional, we aim to be friendly and take an interest in our guests.</p>
            </div>
          </div>
          <div class="principle">
            <div class="p-num">02</div>
            <div>
              <h4>Guests, not numbers.</h4>
              <p>It can get busy in the summer months, but we always try to get to know our divers over a cup of tea or coffee. Many guests have rewarded us with their friendship and loyalty.</p>
            </div>
          </div>
          <div class="principle">
            <div class="p-num">03</div>
            <div>
              <h4>Safety comes first.</h4>
              <p>If you earn a certification at our diving center, you can be sure you deserve it. Our instructors make sure you truly understand the material and know what you're doing underwater before letting you pass.</p>
            </div>
          </div>
          <div class="principle">
            <div class="p-num">04</div>
            <div>
              <h4>Care for the sea.</h4>
              <p>Climate change and pollution are among the top global problems. We try to do our part in conserving the ocean — through clean-up events and reducing plastic waste.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section sec-team">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow"><span class="num">03</span> The crew</div>
          <h2>Our instructors <em>and dive guides.</em></h2>
        </div>
        <p class="intro">
          From our "Our story" page: motivated professionals with a passion for their work. The roster, portraits and short bios belong here — they're a placeholder until the owner confirms who's on the 2026 crew.
        </p>
      </div>

      <div class="team-grid">
        <article class="team-card">
          <div class="portrait">
            <img src={teamPortrait.src} alt="Placeholder instructor portrait." />
            <span class="badge">Placeholder — to be confirmed</span>
          </div>
          <div class="body">
            <h3>Lorem Ipsum</h3>
            <div class="role">PADI Instructor · Role TBC</div>
            <p>
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Short bio replaces this paragraph once the owner confirms team members and consents to public names.
            </p>
            <div class="meta">
              <span><b>Experience</b> Lorem ipsum</span>
              <span><b>Languages</b> Lorem ipsum</span>
            </div>
          </div>
        </article>

        <article class="team-card">
          <div class="portrait">
            <img src={teamBriefing.src} alt="Placeholder instructor portrait." />
            <span class="badge">Placeholder — to be confirmed</span>
          </div>
          <div class="body">
            <h3>Lorem Ipsum</h3>
            <div class="role">PADI Instructor · Role TBC</div>
            <p>
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Short bio replaces this paragraph once the owner confirms team members and consents to public names.
            </p>
            <div class="meta">
              <span><b>Experience</b> Lorem ipsum</span>
              <span><b>Languages</b> Lorem ipsum</span>
            </div>
          </div>
        </article>
      </div>

      <p class="press-note">
        For photo requests, interviews and other press enquiries, please contact the DC Mihurić CEO <strong>Maggy Car</strong> at <a href="mailto:info@mihuric.hr">info@mihuric.hr</a>.
      </p>
    </div>
  </section>

  <section class="section alt sec-timeline">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow"><span class="num">04</span> The arc</div>
          <h2>From 1995 <em>to today.</em></h2>
        </div>
        <p class="intro">
          A short timeline with a few real year markers will live here. The entries below are placeholders — dates will be replaced with ones the owner confirms.
        </p>
      </div>

      <ol class="timeline">
        <li class="tl-item">
          <span class="year">1995</span>
          <h4>DC Mihurić opens.</h4>
          <p>Committed from day one to quality diver training according to the PADI program, and to introducing divers to our chunk of the underwater world.</p>
        </li>
        <li class="tl-item">
          <span class="year">Lorem</span>
          <h4>Lorem ipsum milestone.</h4>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Placeholder — replace with a real milestone from the owner (e.g. year the shop moved into its current building).</p>
        </li>
        <li class="tl-item">
          <span class="year">Lorem</span>
          <h4>PADI 5 Star IDC upgrade.</h4>
          <p>Lorem ipsum — the shop grew into a 5-Star IDC Resort, offering IDC courses to aspiring diving instructors. Exact year to be confirmed.</p>
        </li>
        <li class="tl-item">
          <span class="year">Lorem</span>
          <h4>Technical diving added.</h4>
          <p>Lorem ipsum — we moved out of our recreational "comfort zone" once more and started offering technical diving courses. Exact year to be confirmed.</p>
        </li>
        <li class="tl-item">
          <span class="year">2026</span>
          <h4>Thirty-one years on.</h4>
          <p>Still connecting with divers, still refining the courses, still finding new sites. If you have any questions, don't hesitate to get in touch.</p>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero { padding: var(--spacing-16) 0 var(--spacing-12); }
  .about-hero .kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--spacing-5);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .about-hero .kicker::before {
    content: "";
    width: 24px;
    height: 1px;
    background: var(--color-accent);
  }
  .about-hero h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(44px, 6.5vw, 96px);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 var(--spacing-5);
    font-variation-settings: "opsz" 80;
    max-width: 18ch;
  }
  .about-hero h1 em { font-style: italic; color: var(--color-accent); }
  .about-hero .lede {
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    max-width: 60ch;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .about-hero .lede strong { color: var(--color-ink); font-weight: 500; }
  .about-hero .lede em { font-style: italic; color: var(--color-accent); }

  .identity-strip {
    margin-top: var(--spacing-12);
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-6);
  }
  .identity-strip .num {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 5vw, 72px);
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--color-ink);
  }
  .identity-strip .num em {
    font-style: italic;
    font-size: 0.5em;
    color: var(--color-accent);
    margin-left: 4px;
  }
  .identity-strip .label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: var(--spacing-3) 0 6px;
  }
  .identity-strip .sub {
    font-size: 13px;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }

  .section { padding: var(--spacing-24) 0; }
  .section.alt { background: var(--color-surface-muted); }
  .section.dark {
    background: var(--color-deep-ink);
    color: var(--color-brand-contrast);
  }
  .section-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-10);
    align-items: end;
    margin-bottom: var(--spacing-12);
  }
  .section-head .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--spacing-4);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .section-head .eyebrow .num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-muted);
    padding: 3px 7px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
  }
  .section.dark .section-head .eyebrow .num {
    color: oklch(0.98 0.01 90 / 0.55);
    border-color: oklch(0.98 0.01 90 / 0.2);
  }
  .section-head h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(36px, 4.5vw, 56px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
    max-width: 18ch;
    font-variation-settings: "opsz" 56;
  }
  .section-head h2 em { font-style: italic; color: var(--color-accent); }
  .section.dark .section-head h2 { color: var(--color-brand-contrast); }
  .section.dark .section-head h2 em { color: var(--color-accent-warm); }
  .section-head .intro {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 50ch;
    margin: 0;
  }
  .section.dark .section-head .intro { color: oklch(0.98 0.01 90 / 0.7); }

  .place-wrap {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-6);
  }
  .wide-image {
    grid-column: 1 / -1;
    margin: 0 0 var(--spacing-4);
    position: relative;
    border-radius: var(--radius-card);
    overflow: hidden;
    aspect-ratio: 21 / 9;
  }
  .wide-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .wide-image .caption {
    position: absolute;
    bottom: var(--spacing-4);
    left: var(--spacing-4);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: oklch(0.98 0.01 90 / 0.85);
    background: oklch(0.13 0.04 245 / 0.5);
    backdrop-filter: blur(8px);
    padding: 6px 12px;
    border-radius: 4px;
  }
  .place-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--spacing-6);
  }
  .place-panel h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 26px;
    letter-spacing: -0.015em;
    margin: 0 0 4px;
  }
  .place-panel .boat-name {
    color: var(--color-accent);
    font-style: italic;
  }
  .place-panel .pronunciation {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-ink-soft);
    margin: 0 0 var(--spacing-4);
  }
  .place-panel p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 var(--spacing-5);
  }
  .place-panel .specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-4);
    padding-top: var(--spacing-4);
    border-top: 1px solid var(--color-border);
  }
  .place-panel .spec-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-bottom: 4px;
  }
  .place-panel .spec-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.005em;
    color: var(--color-ink);
    line-height: 1.3;
  }

  .credo {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--spacing-12);
    align-items: start;
  }
  .credo-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 2.4vw, 30px);
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: oklch(0.98 0.01 90);
    max-width: 30ch;
    margin: 0;
    padding-left: var(--spacing-6);
    border-left: 3px solid var(--color-accent);
  }
  .credo-quote cite {
    display: block;
    margin-top: var(--spacing-4);
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: oklch(0.98 0.01 90 / 0.55);
  }
  .principles { display: grid; gap: var(--spacing-8); }
  .principle {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-5);
    align-items: start;
  }
  .principle .p-num {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 32px;
    letter-spacing: -0.02em;
    color: var(--color-accent-warm);
    font-variation-settings: "opsz" 48;
    line-height: 1;
    padding-top: 2px;
  }
  .principle h4 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.01em;
    margin: 0 0 var(--spacing-2);
    color: oklch(0.98 0.01 90);
  }
  .principle p {
    font-size: 14px;
    line-height: 1.6;
    color: oklch(0.98 0.01 90 / 0.75);
    margin: 0;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-6);
  }
  .team-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: grid;
    grid-template-columns: 200px 1fr;
  }
  .team-card .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .team-card .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.1);
  }
  .team-card .portrait .badge {
    position: absolute;
    bottom: var(--spacing-3);
    left: var(--spacing-3);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 4px;
    background: oklch(0.13 0.04 245 / 0.72);
    color: oklch(0.98 0.01 90);
    backdrop-filter: blur(6px);
  }
  .team-card .body {
    padding: var(--spacing-6);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }
  .team-card h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .team-card .role {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .team-card p {
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .team-card .meta {
    margin-top: auto;
    padding-top: var(--spacing-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-muted);
  }
  .team-card .meta b {
    color: var(--color-ink);
    font-weight: 500;
    margin-right: 6px;
  }

  .press-note {
    margin-top: var(--spacing-8);
    padding-top: var(--spacing-6);
    border-top: 1px solid var(--color-border);
    font-size: 13px;
    color: var(--color-ink-muted);
    line-height: 1.55;
    max-width: 70ch;
  }
  .press-note strong { color: var(--color-ink); font-weight: 500; }
  .press-note a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-border-strong);
    text-decoration: none;
  }
