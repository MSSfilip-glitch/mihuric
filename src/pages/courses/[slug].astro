---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Separator from '@/components/ui/Separator.astro';
import Schema from '@/components/Schema.astro';

export async function getStaticPaths() {
  const entries = await getCollection('courses', (e) => e.data.locale === 'en' && !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<BaseLayout title={d.title} description={d.summary} image={d.hero?.src} schemaType="none">
  <Schema type="course" name={d.title} description={d.summary} priceFrom={d.priceFrom} />

  <Container size="default" class="py-[var(--spacing-section)]">
    <nav aria-label="Breadcrumb" class="text-sm text-[var(--color-ink-muted)]">
      <a href="/" class="hover:underline">Home</a> /
      <a href="/courses/" class="hover:underline">Courses</a> /
      <span>{d.title}</span>
    </nav>

    <header class="mt-4">
      <Badge variant="muted">{d.track}</Badge>
      <h1 class="mt-2 text-4xl md:text-5xl font-semibold">{d.title}</h1>
      <p class="mt-3 text-[var(--color-ink-muted)]">{d.summary}</p>
    </header>

    {d.hero && (
      <figure class="mt-6">
        <Image src={d.hero} alt={d.title} widths={[640, 960, 1440]} sizes="(min-width: 1024px) 960px, 100vw" />
      </figure>
    )}

    <dl class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
      {d.duration && (
        <div><dt class="text-[var(--color-ink-muted)]">Duration</dt><dd class="font-medium">{d.duration}</dd></div>
      )}
      {d.certification && (
        <div><dt class="text-[var(--color-ink-muted)]">Certification</dt><dd class="font-medium">{d.certification}</dd></div>
      )}
      {d.priceFrom && (
        <div><dt class="text-[var(--color-ink-muted)]">From</dt><dd class="font-medium">{d.priceFrom.amount} {d.priceFrom.currency}</dd></div>
      )}
    </dl>

    {d.prerequisites.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold">Prerequisites</h2>
        <ul class="mt-2 list-disc pl-5">
          {d.prerequisites.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    {d.includes.length > 0 && (
      <section class="mt-6">
        <h2 class="text-xl font-semibold">What's included</h2>
        <ul class="mt-2 list-disc pl-5">
          {d.includes.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    <Separator class="my-8" />
    <article class="prose max-w-none"><Content /></article>

    <aside class="mt-10 p-6 border border-[var(--color-border)] rounded-[var(--radius-card)]">
      <h2 class="text-lg font-semibold">Ready to sign up?</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <Button as="a" href="/contact/">Start your booking</Button>
        <Button as="a" href="/courses/" variant="outline">Other courses</Button>
      </div>
    </aside>
  </Container>
</BaseLayout>
