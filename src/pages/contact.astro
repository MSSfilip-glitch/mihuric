---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';
import Label from '@/components/ui/Label.astro';
import { SITE } from '@/lib/site';

// POSTs to Web3Forms when PUBLIC_WEB3FORMS_KEY is set; otherwise the form
// is omitted entirely and the page shows just email/phone/address.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const formReady = Boolean(accessKey);
---

<BaseLayout
  title="Contact"
  description="Get in touch with Diving Center Mihurić in Selce, Croatia. Email, phone, and a direct inquiry form."
>
  <Container size="default" class="py-[var(--spacing-section)]">
    <h1 class="text-4xl md:text-5xl font-semibold">Plan your dive with us</h1>
    <p class="mt-4 max-w-2xl text-[var(--color-ink-muted)]">
      {formReady
        ? "Tell us when you're coming, what you're certified for, and what you'd like to dive. We reply to every inquiry — usually within a day."
        : "Reach us by email or phone — we reply to every message, usually within a day."}
    </p>

    <div class={formReady ? 'mt-10 grid gap-10 md:grid-cols-3' : 'mt-10'}>
      {formReady && (
        <section class="md:col-span-2">
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-4"
            aria-label="Dive inquiry form"
          >
            <input type="hidden" name="access_key" value={accessKey} />
            <input type="hidden" name="from_name" value="mihuric.hr inquiry" />
            <input type="hidden" name="subject" value="New dive inquiry via website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <div>
              <Label for="name">Name</Label>
              <Input name="name" required autocomplete="name" />
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <Label for="email">Email</Label>
                <Input name="email" type="email" required autocomplete="email" />
              </div>
              <div>
                <Label for="phone">Phone (optional)</Label>
                <Input name="phone" type="tel" autocomplete="tel" />
              </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <Label for="arrival">Arrival date</Label>
                <Input name="arrival" type="date" />
              </div>
              <div>
                <Label for="departure">Departure date</Label>
                <Input name="departure" type="date" />
              </div>
            </div>

            <div>
              <Label for="certification">Certification level</Label>
              <select
                id="certification"
                name="certification"
                class="block w-full h-10 px-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-input)]"
              >
                <option value="">Pick one…</option>
                <option>No certification — I'd like to try</option>
                <option>Open Water Diver</option>
                <option>Advanced Open Water Diver</option>
                <option>Rescue Diver</option>
                <option>Divemaster or Instructor</option>
                <option>Tec diver</option>
              </select>
            </div>

            <div>
              <Label for="interest">What are you interested in?</Label>
              <Textarea name="interest" rows={5} placeholder="Wrecks, reefs, a specific course, family discovery dive…" />
            </div>

            <Button type="submit" size="lg">Send inquiry</Button>
          </form>
        </section>
      )}

      <aside class="space-y-6 text-sm">
        <section>
          <h2 class="font-semibold">Email</h2>
          <p class="mt-1"><a href={`mailto:${SITE.email}`} class="hover:underline">{SITE.email}</a></p>
        </section>
        <section>
          <h2 class="font-semibold">Phone</h2>
          {SITE.phones.map((p) => (
            <p><a href={`tel:${p.replace(/\s+/g, '')}`} class="hover:underline">{p}</a></p>
          ))}
        </section>
        <section>
          <h2 class="font-semibold">Address</h2>
          <address class="not-italic text-[var(--color-ink-muted)]">
            {SITE.address.street}<br />
            {SITE.address.postal} {SITE.address.city}<br />
            {SITE.address.country}
          </address>
        </section>
        <section>
          <h2 class="font-semibold">GPS</h2>
          <p class="text-[var(--color-ink-muted)]">{SITE.gps.lat}, {SITE.gps.lng}</p>
        </section>
      </aside>
    </div>
  </Container>
</BaseLayout>
