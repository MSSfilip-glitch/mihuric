---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';

// POSTs to Web3Forms when PUBLIC_WEB3FORMS_KEY is set; otherwise the form
// is omitted entirely and the page shows just email/phone/address.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const formReady = Boolean(accessKey);
---

<BaseLayout
  title="Contact — Diving Center Mihurić"
  description="Get in touch with Diving Center Mihurić in Selce, Croatia. Email, phone, and a direct inquiry form."
  active="contact"
>
  <div class="page-wrap">
    <div class="breadcrumbs">
      <a href="/">Home</a><span class="sep">/</span>
      <span>Contact</span>
    </div>
  </div>

  <section class="contact-hero">
    <div class="page-wrap">
      <div class="kicker">Info &amp; contact · since 1995</div>
      <h1>Real people, <em>one inbox.</em></h1>
      <p class="lede">
        <strong>Every message lands in {SITE.email}.</strong> We will get back to you with an offer or an answer as soon as possible.
      </p>

      <div class="status-bar" id="status-bar">
        <div class="dot" aria-hidden="true"></div>
        <div class="who">
          <b id="status-text">Opening hours — <em>placeholder.</em></b>
          <span id="status-sub">Real hours will replace this line once the owner confirms them.</span>
        </div>
        <div class="when" id="status-when"></div>
      </div>
    </div>
  </section>

  <section class="contact-main">
    <div class="page-wrap">
      <div class="contact-details">
        <div class="block">
          <div class="label">Address</div>
          <div class="value">
            Diving Center Mihurić<br />
            {SITE.address.street}<br />
            {SITE.address.postal} {SITE.address.city}, {SITE.address.country}
          </div>
          <div class="sub">Placeholder · location hint (parking, landmark) to be confirmed</div>
        </div>

        <div class="block">
          <div class="label">Email &amp; phone</div>
          <div class="value"><a href={`mailto:${SITE.email}`}>{SITE.email}</a></div>
          <div class="sub">For bookings, availability, gear questions</div>
          {SITE.phones.map((p) => (
            <div class="value" style="margin-top: var(--spacing-4);">
              <a href={`tel:${p.replace(/\s+/g, '')}`}>{p}</a>
            </div>
          ))}
        </div>

        <div class="block">
          <div class="label">GPS</div>
          <div class="value">{SITE.gps.lat.toFixed(4)}° N · {SITE.gps.lng.toFixed(4)}° E</div>
          <div class="sub">
            <a
              href={`https://www.google.com/maps/@${SITE.gps.lat},${SITE.gps.lng},15z`}
            >Open in Google Maps →</a>
          </div>
        </div>

        <div class="block">
          <div class="label">Follow</div>
          <div class="value"><a href={SITE.social.facebook} rel="me noopener" target="_blank">Facebook</a></div>
          <div class="value" style="margin-top: var(--spacing-2);"><a href={SITE.social.instagram} rel="me noopener" target="_blank">Instagram · @dc_mihuric</a></div>
        </div>
      </div>

      {formReady && (
        <div class="contact-form-card">
          <h2>Send a message</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            aria-label="Dive inquiry form"
          >
            <input type="hidden" name="access_key" value={accessKey} />
            <input type="hidden" name="from_name" value="mihuric.hr inquiry" />
            <input type="hidden" name="subject" value="New dive inquiry via website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
            <div class="row">
              <label>Name<input name="name" required autocomplete="name" /></label>
            </div>
            <div class="row split">
              <label>Email<input name="email" type="email" required autocomplete="email" /></label>
              <label>Phone<input name="phone" type="tel" autocomplete="tel" /></label>
            </div>
            <div class="row">
              <label>What are you interested in?
                <textarea name="interest" rows="5" placeholder="Wrecks, reefs, a specific course, family discovery dive…"></textarea>
              </label>
            </div>
            <button type="submit" class="btn btn-primary btn-arrow">Send inquiry</button>
          </form>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: var(--spacing-16) 0 var(--spacing-12);
  }
  .contact-hero h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(44px, 6vw, 88px);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: var(--spacing-5) 0 var(--spacing-5);
    font-variation-settings: "opsz" 80;
    max-width: 18ch;
  }
  .contact-hero h1 em {
    font-style: italic;
    color: var(--color-accent);
  }
  .contact-hero .lede {
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    max-width: 58ch;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .contact-hero .lede strong { color: var(--color-ink); font-weight: 500; }

  .status-bar {
    margin-top: var(--spacing-10);
    padding: var(--spacing-4) var(--spacing-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-ok);
    border-radius: var(--radius-card);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--spacing-5);
    align-items: center;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .status-bar .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-ok);
    box-shadow: 0 0 0 4px oklch(0.62 0.14 165 / 0.2);
    animation: contact-pulse 2s ease-in-out infinite;
  }
  @keyframes contact-pulse {
    0%, 100% { box-shadow: 0 0 0 4px oklch(0.62 0.14 165 / 0.2); }
    50% { box-shadow: 0 0 0 7px oklch(0.62 0.14 165 / 0.05); }
  }
  .status-bar b {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-ink);
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .status-bar .who span {
    display: block;
    color: var(--color-ink-muted);
    font-size: 12px;
    margin-top: 4px;
  }
  .status-bar .when { color: var(--color-ink-muted); }

  .contact-main { padding-bottom: var(--spacing-20); }
  .contact-details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-10);
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-10);
  }
  .contact-details .block .label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--spacing-3);
  }
  .contact-details .block .value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    line-height: 1.35;
  }
  .contact-details .block .value a {
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 1px;
    color: inherit;
  }
  .contact-details .block .value a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .contact-details .block .sub {
    margin-top: var(--spacing-2);
    font-size: 13px;
    color: var(--color-ink-muted);
  }
  .contact-details .block .sub a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-strong);
  }

  .contact-form-card {
    margin-top: var(--spacing-12);
    padding: var(--spacing-10);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  .contact-form-card h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 36px);
    letter-spacing: -0.015em;
    margin: 0 0 var(--spacing-6);
  }
  .contact-form-card .row { margin-bottom: var(--spacing-4); }
  .contact-form-card .row.split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-4);
  }
  .contact-form-card label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 6px;
  }
  .contact-form-card input,
  .contact-form-card textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-input);
    padding: 12px 14px;
    margin-top: 6px;
  }
  .contact-form-card input:focus,
  .contact-form-card textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .contact-form-card textarea { resize: vertical; min-height: 120px; }

  @media (max-width: 720px) {
    .contact-details { grid-template-columns: 1fr; gap: var(--spacing-6); }
    .status-bar { grid-template-columns: 1fr; text-align: left; }
    .contact-form-card .row.split { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function updateClock() {
    const when = document.getElementById('status-when');
    if (!when) return;
    const fmt = () => {
      const now = new Date();
      const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      const pad = (n) => String(n).padStart(2, '0');
      return `${days[now.getDay()]} · ${pad(now.getHours())}:${pad(now.getMinutes())} local · CET/CEST`;
    };
    when.textContent = fmt();
    setInterval(() => { when.textContent = fmt(); }, 60 * 1000);
  })();
</script>
