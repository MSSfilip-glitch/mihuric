---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/site';
import heroDiverSilhouette from '@/assets/design/home-assets/hero-diver-silhouette.jpg';
import heroIntoBlue from '@/assets/design/home-assets/hero-into-blue.jpg';
import splitOverUnder from '@/assets/design/home-assets/split-over-under.jpg';
import siteDeep from '@/assets/design/home-assets/site-deep.jpg';
import sitePeltastis from '@/assets/design/home-assets/site-peltastis.jpg';
import siteHouseReef from '@/assets/design/home-assets/site-house-reef.jpg';
import siteGorgonian from '@/assets/design/home-assets/site-gorgonian.jpg';
import siteAnchovy from '@/assets/design/home-assets/site-anchovy.jpg';
import siteWallYellow from '@/assets/design/home-assets/site-wall-yellow.jpg';
import teamBriefing from '@/assets/design/home-assets/team-briefing.jpg';
---

<BaseLayout
  title={`${SITE.name} — Selce, Croatia`}
  description={`${SITE.tagline}. PADI courses, guided dives at 30+ Adriatic sites — wrecks, reefs, caves, walls.`}
  alternates={{ en: '/', hr: '/hr/' }}
  variant="home"
>
  <section class="hero">
    <div class="hero-bg" style={`background-image: url('${heroDiverSilhouette.src}');`}></div>
    <div class="bubble-layer" id="bubble-layer" aria-hidden="true"></div>

    <div class="page-wrap hero-inner">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        <span>Diving in Selce, Croatia</span>
        <span class="since">· since 1995</span>
      </div>
      <h1 class="hero-headline">
        Are you getting enough <em>Vitamin Sea?</em>
      </h1>
      <p class="hero-deck">
        Get your dose at our diving center by trying scuba diving, completing a PADI course or enjoying new diving experiences with your buddy or our professional staff. Whether you are new to scuba diving or an experienced diver, we've got you covered.
      </p>
      <div class="hero-ctas">
        <a href="/plan-a-trip/" class="btn btn-primary btn-arrow">Plan a trip</a>
        <a href="#courses" class="btn btn-ghost-light btn-arrow">See courses</a>
      </div>
      <div class="hero-meta">
        <div class="cell"><span>Dive sites</span><b>30<span class="unit"> in the area</span></b></div>
        <div class="cell"><span>Water on a sunny day</span><b>up to 30<span class="unit"> m transparency</span></b></div>
        <div class="cell"><span>Summer sea temp</span><b>20–25<span class="unit"> °C · Jul–Sep</span></b></div>
        <div class="cell"><span>Certification</span><b>PADI 5★ IDC Resort</b></div>
      </div>
    </div>

    <div class="scroll-nudge" aria-hidden="true">
      <span>Scroll</span>
      <span class="tick"></span>
    </div>
  </section>

  <section class="section audience-section">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">02 · Start here</div>
          <h2 class="section-title">Two ways in, <em>one sea.</em></h2>
        </div>
        <div class="head-right">
          Whether you've never worn a mask or you have hundreds of logged dives, there's a version of this week for you.
        </div>
      </div>
      <div class="audience-grid">
        <a href="/courses/discovery/" class="audience-card audience-card--new" style={`--card-bg: url('${splitOverUnder.src}');`}>
          <div class="bg" aria-hidden="true"></div>
          <div class="kicker">For first-timers</div>
          <h3>I'm new<br /><em>to diving.</em></h3>
          <p>Never tried scuba — or had a long break and want to refresh your memory. Start with a Discover Scuba session on the house reef with one of our instructors.</p>
          <span class="enter">
            <small>Discovery dives · no certification needed</small>
            Start with a try dive
          </span>
        </a>
        <a href="/dive-sites/" class="audience-card audience-card--cert" style={`--card-bg: url('${siteDeep.src}');`}>
          <div class="bg" aria-hidden="true"></div>
          <div class="kicker">For certified divers</div>
          <h3>I'm already<br /><em>certified.</em></h3>
          <p>Walk into the house reef or join our speedboat <em>Triton</em> out to a shipwreck, reef or cave. We visit around 30 sites; boat runs twice a day, morning and afternoon.</p>
          <span class="enter">
            <small>Guided dives · shore &amp; boat · night dives on request</small>
            Pick your dive plan
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="section sites-section" id="dive-sites">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">03 · Featured dive sites</div>
          <h2 class="section-title">30 sites, <em>one boat.</em></h2>
        </div>
        <div class="head-right">
          Reefs, shipwrecks and caves reached by our speedboat <em>Triton</em>, plus shore dives from the house reef. <a href="/dive-sites/">See all sites →</a>
        </div>
      </div>
      <div class="sites-grid">
        <a href="/dive-sites/shipwreck-peltastis/" class="site-card span-lg" style={`--site-bg: url('${sitePeltastis.src}');`}>
          <div class="bg"></div>
          <div class="flag">Signature</div>
          <div class="site-tag">
            <span>Wreck dive</span>
          </div>
          <h4>Shipwreck Peltastis</h4>
          <div class="site-meta">
            <span>Depth<b>8–31 m</b></span>
            <span>Level<b>AOWD</b></span>
          </div>
        </a>

        <a href="/dive-sites/house-reef/" class="site-card span-md" style={`--site-bg: url('${siteHouseReef.src}');`}>
          <div class="bg"></div>
          <div class="flag flag-soft">Shore entry</div>
          <div class="site-tag">
            <span>House reef</span>
          </div>
          <h4>House reef</h4>
          <div class="site-meta">
            <span>Depth<b>2–35 m</b></span>
            <span>Level<b>OWD</b></span>
          </div>
        </a>

        <a href="/dive-sites/shipwreck-ss-regolo/" class="site-card span-tall" style={`--site-bg: url('${siteGorgonian.src}');`}>
          <div class="bg"></div>
          <div class="site-tag">
            <span>Wreck</span>
          </div>
          <h4>Shipwreck SS Regolo</h4>
          <div class="site-meta">
            <span>Depth<b>Lorem</b></span>
            <span>Level<b>Lorem</b></span>
          </div>
        </a>

        <a href="/dive-sites/shipwreck-jakljan/" class="site-card span-sm" style={`--site-bg: url('${siteAnchovy.src}');`}>
          <div class="bg"></div>
          <div class="site-tag">
            <span>Wreck</span>
          </div>
          <h4>Shipwreck Jakljan</h4>
          <div class="site-meta">
            <span>Depth<b>Lorem</b></span>
          </div>
        </a>

        <a href="/dive-sites/yellow-coral/" class="site-card span-sm" style={`--site-bg: url('${siteWallYellow.src}');`}>
          <div class="bg"></div>
          <div class="site-tag">
            <span>Reef</span>
          </div>
          <h4>Yellow coral</h4>
          <div class="site-meta">
            <span>Depth<b>Lorem</b></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section house-reef">
    <div class="page-wrap">
      <div class="house-reef-grid">
        <div class="photo" style={`background-image: url('${siteHouseReef.src}');`} aria-label="Shore entry on the Mihurić house reef"></div>
        <div class="house-reef-text">
          <div class="section-eyebrow house-reef-eyebrow">04 · House reef</div>
          <h2>Right in <em>front of us.</em></h2>
          <p class="lead">
            A beautiful house reef awaits you right in front of our diving center — load up your gear, take a few steps and you're there. Ideal for novice as well as experienced divers: a tribute to Neptune, smaller wrecks, a 2 m tall anchor, and the usual cast of fish, octopuses, slugs and sea horses.
          </p>
          <div class="house-reef-facts">
            <div class="fact"><span>Min / max depth</span><b>2 / 35 m</b></div>
            <div class="fact"><span>Entry</span><b>Shore</b></div>
            <div class="fact"><span>Certification</span><b>OWD</b></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section courses-section" id="courses">
    <div class="page-wrap">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">05 · PADI Courses</div>
          <h2 class="section-title">Learn here, <em>dive anywhere.</em></h2>
        </div>
        <div class="head-right">
          We run the full recreational ladder and selected tech + speciality. Certifications are PADI-recognised worldwide. <a href="/courses/">All courses →</a>
        </div>
      </div>
      <div class="courses-ladder">
        <article class="course-card">
          <div class="rung"><span class="num">01</span><span>Recreational</span></div>
          <h4>Open Water Diver</h4>
          <p>The entry certification. Minimum age 12 (10–11 year-olds earn a Junior OWD). Five days, nine dives, maximum depth 18 m. After the course you can dive with a buddy to those depths.</p>
          <div class="course-meta">
            <div><span>Duration</span><b>5 days</b></div>
            <div><span>Max depth</span><b>18 m</b></div>
          </div>
          <a href="/courses/recreational/" class="course-cta">Course details</a>
        </article>
        <article class="course-card featured">
          <div class="rung"><span class="num">02</span><span>Recreational</span></div>
          <h4>Advanced Open Water</h4>
          <p>Five adventure dives — navigation and deep are mandatory; you choose the rest with your instructor. Minimum age 15 (12–14 year-olds earn a Junior AOWD). Two to three days, maximum depth 30 m.</p>
          <div class="course-meta">
            <div><span>Duration</span><b>2–3 days</b></div>
            <div><span>Max depth</span><b>30 m</b></div>
          </div>
          <a href="/courses/recreational/" class="course-cta">Course details</a>
        </article>
        <article class="course-card">
          <div class="rung"><span class="num">03</span><span>Specialty</span></div>
          <h4>PADI Specialty courses</h4>
          <p>Deep Diver, Enriched Air (Nitrox), Night, Wreck, Digital Underwater Photographer, Dry Suit, Peak Performance Buoyancy, Underwater Naturalist, Underwater Navigator, Project AWARE and more.</p>
          <div class="course-meta">
            <div><span>Duration</span><b>Varies</b></div>
            <div><span>Format</span><b>1–2 day add-ons</b></div>
          </div>
          <a href="/courses/specialty/" class="course-cta">Course details</a>
        </article>
      </div>
    </div>
  </section>

  <section class="numbers-section">
    <div class="page-wrap">
      <div class="numbers-grid">
        <div class="num-cell">
          <div class="big">1995</div>
          <div class="label">Offering <b>PADI diver training and guided diving</b> in Selce since.</div>
        </div>
        <div class="num-cell">
          <div class="big">5★</div>
          <div class="label"><b>PADI IDC Resort</b> — the highest rating a PADI dive center can hold.</div>
        </div>
        <div class="num-cell">
          <div class="big">30<sup>+</sup></div>
          <div class="label">Charted <b>dive sites</b> in the area — shipwrecks, reefs, caves.</div>
        </div>
        <div class="num-cell">
          <div class="big">30<sup>m</sup></div>
          <div class="label">Water <b>transparency</b> on a sunny day, per our weather page.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section team-section" id="about">
    <div class="page-wrap">
      <div class="team-grid">
        <div class="team-photo" style={`background-image: url('${teamBriefing.src}');`} aria-label="Team briefing on the boat, Mihurić"></div>
        <div class="team-text">
          <div class="section-eyebrow">07 · About</div>
          <p class="quote">
            Lorem ipsum dolor sit amet — this is the space we'd put a quote from the owner. Pulled out and attributed when we have the real one.
          </p>
          <div class="byline">
            <b>DC Mihurić</b><span class="sep">·</span><span>PADI 5★ IDC Resort</span><span class="sep">·</span><span>Since 1995</span>
          </div>
          <p class="story">
            Ever since we've first opened our doors, we've been committed to providing quality diver training according to the PADI program, as well as introducing divers to our chunk of the underwater world. Throughout the years, our educational offer has expanded — from recreational PADI courses through IDC instruction, all the way to technical diving.
          </p>
          <a href="/about/" class="btn btn-ghost-dark btn-arrow">Read the full story</a>
        </div>
      </div>
    </div>
  </section>

  <section class="booking-cta" id="book">
    <div class="booking-bg" style={`background-image: url('${heroIntoBlue.src}');`}></div>
    <div class="page-wrap">
      <div class="booking-inner">
        <div>
          <div class="section-eyebrow booking-eyebrow">08 · Plan your trip</div>
          <h2>We are at your disposal <em>for any questions.</em></h2>
          <p class="deck">Email us about diving courses, guided dives or a diving vacation in Selce. We'll come back to you with an offer as soon as possible.</p>
          <div class="cta-row">
            <a href="/contact/" class="btn btn-primary btn-arrow">Send an enquiry</a>
            <span class="or">or</span>
            <a href={`tel:${SITE.phones[0].replace(/\s+/g, '')}`} class="phone-cta">
              <span>Call us direct</span>
              <b>{SITE.phones[0]}</b>
            </a>
          </div>
        </div>
        <aside class="booking-aside">
          <h4>Offered services</h4>
          <ul>
            <li>
              <span class="label">Discovery dives</span>
              <span class="meta">no certification needed</span>
              <span class="price">—</span>
            </li>
            <li>
              <span class="label">Guided shore &amp; boat dives</span>
              <span class="meta">cert. divers · 2×/day</span>
              <span class="price">—</span>
            </li>
            <li>
              <span class="label">PADI recreational courses</span>
              <span class="meta">Scuba Diver, OWD, AOWD…</span>
              <span class="price">—</span>
            </li>
            <li>
              <span class="label">PADI Pro &amp; Tec</span>
              <span class="meta">DM, IDC, Tec courses</span>
              <span class="price">—</span>
            </li>
          </ul>
          <div class="fine">Pricing is handled on request — <a href="/contact/" style="color: inherit; border-bottom: 1px solid currentColor;">get in touch</a> with your dates and certification level.</div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Home palette & layout tokens */
  :global(:root) {
    --page-max: 1280px;
    --page-pad: clamp(20px, 4vw, 48px);
    --sec-gap: 96px;
  }

  .page-wrap {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 0 var(--page-pad);
  }

  /* ─── HERO ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    color: oklch(0.98 0.01 90);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    background: var(--color-deep-ink);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: -2;
    animation: heroFade 1.4s ease-out both, heroBgKenBurns 16s ease-out both;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg,
        oklch(0.12 0.04 245 / 0.55) 0%,
        oklch(0.12 0.04 245 / 0.20) 35%,
        oklch(0.12 0.04 245 / 0.45) 75%,
        oklch(0.12 0.04 245 / 0.85) 100%);
  }
  .bubble-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .bubble-layer :global(.b) {
    position: absolute;
    bottom: -30px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 32% 32%, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.35) 18%, rgba(255,255,255,0) 42%),
      radial-gradient(circle at 50% 50%, rgba(255,255,255,0) 55%, rgba(180,220,255,0.35) 78%, rgba(255,255,255,0.75) 92%, rgba(255,255,255,0) 100%);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.45);
    opacity: 0;
    animation: bubbleRise linear infinite;
    will-change: transform, opacity;
  }
  @keyframes bubbleRise {
    0%   { transform: translate(0, 0) scale(0.8); opacity: 0; }
    10%  { opacity: 0.9; }
    90%  { opacity: 0.8; }
    100% { transform: translate(var(--dx, 20px), calc(-1 * var(--h, 820px))) scale(1.2); opacity: 0; }
  }
  @keyframes heroEnter {
    from { opacity: 0; transform: translateY(24px); filter: blur(4px); }
    to   { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  @keyframes heroFade { from { opacity: 0 } to { opacity: 1 } }
  @keyframes heroBgKenBurns { from { transform: scale(1.08) } to { transform: scale(1) } }

  .hero-inner {
    flex: 1;
    display: grid;
    align-content: end;
    padding-bottom: clamp(60px, 10vh, 120px);
    padding-top: clamp(140px, 18vh, 200px);
    position: relative;
    z-index: 1;
  }
  .hero-eyebrow,
  .hero-headline,
  .hero-deck,
  .hero-ctas,
  .hero-meta {
    opacity: 0;
    animation: heroEnter 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero-eyebrow { animation-delay: 0.20s; }
  .hero-headline { animation-delay: 0.35s; animation-duration: 1.1s; }
  .hero-deck { animation-delay: 0.65s; }
  .hero-ctas { animation-delay: 0.85s; }
  .hero-meta { animation-delay: 1.05s; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    color: oklch(0.98 0.01 90 / 0.8);
    margin-bottom: var(--spacing-6);
  }
  .hero-eyebrow .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    display: inline-block;
  }
  .hero-eyebrow .since { opacity: 0.5; }

  .hero-headline {
    font-size: clamp(48px, 8.4vw, 124px);
    line-height: 0.96;
    letter-spacing: -0.035em;
    font-weight: 500;
    max-width: 16ch;
    margin: 0 0 var(--spacing-8);
    font-variation-settings: "opsz" 96;
    color: oklch(0.98 0.01 90);
  }
  .hero-headline em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent-warm);
    letter-spacing: -0.03em;
  }

  .hero-deck {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.3vw, 19px);
    max-width: 52ch;
    color: oklch(0.98 0.01 90 / 0.8);
    font-weight: 300;
    line-height: 1.55;
    margin-bottom: var(--spacing-8);
    text-wrap: pretty;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-12);
    align-items: center;
  }
  .hero-ctas .price-note {
    font-size: 13px;
    color: oklch(0.98 0.01 90 / 0.65);
    font-family: var(--font-body);
  }
  .hero-ctas .price-note b {
    color: oklch(0.98 0.01 90 / 0.95);
    font-weight: 500;
  }

  .btn-ghost-light {
    color: oklch(0.98 0.01 90);
    border: 1px solid oklch(1 0 0 / 0.35);
    background: oklch(1 0 0 / 0.05);
    padding: 11px 20px;
    border-radius: var(--radius-button);
    font-size: 14px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: background 160ms var(--ease-rise);
  }
  .btn-ghost-light:hover { background: oklch(1 0 0 / 0.14); }

  .btn-ghost-dark {
    color: var(--color-ink);
    border: 1px solid var(--color-border-strong);
    background: transparent;
    padding: 11px 20px;
    border-radius: var(--radius-button);
    font-size: 14px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: background 160ms var(--ease-rise);
  }
  .btn-ghost-dark:hover { background: var(--color-surface-muted); }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-6);
    border-top: 1px solid oklch(1 0 0 / 0.18);
    padding-top: var(--spacing-6);
    max-width: 860px;
  }
  .hero-meta .cell span {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: oklch(0.98 0.01 90 / 0.55);
    display: block;
    margin-bottom: 6px;
  }
  .hero-meta .cell b {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.015em;
    color: oklch(0.98 0.01 90);
  }
  .hero-meta .cell b .unit {
    font-weight: 400;
    font-size: 13px;
    color: oklch(0.98 0.01 90 / 0.65);
    margin-left: 2px;
  }

  .scroll-nudge {
    position: absolute;
    bottom: var(--spacing-6);
    right: var(--page-pad);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: oklch(0.98 0.01 90 / 0.7);
    display: flex;
    align-items: center;
    gap: 10px;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    z-index: 2;
  }
  .scroll-nudge .tick {
    width: 1px;
    height: 42px;
    background: linear-gradient(180deg, transparent, oklch(1 0 0 / 0.7), transparent);
    animation: nudge 2.6s var(--ease-swim) infinite;
  }
  @keyframes nudge {
    0%, 100% { transform: translateY(-6px); opacity: 0.4; }
    50% { transform: translateY(6px); opacity: 1; }
  }

  /* ─── SECTIONS ─────────────────────────────────────────────────────── */
  .section { padding: var(--sec-gap) 0; }
  .section-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-12);
  }
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--spacing-3);
  }
  .section-title {
    font-size: clamp(32px, 4.5vw, 56px);
