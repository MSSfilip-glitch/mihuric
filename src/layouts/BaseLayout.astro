---
/**
 * Base page chrome.
 *
 * Intentionally unstyled — a plain semantic frame. Claude Design owns
 * header/footer/nav visual treatment and will overwrite via handoff.
 */
import '@/styles/globals.css';
import SEO from '@/components/SEO.astro';
import Schema from '@/components/Schema.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import HomeHeader from '@/components/HomeHeader.astro';
import { SITE, type Locale } from '@/lib/site';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  image?: string;
  noindex?: boolean;
  alternates?: Partial<Record<Locale, string>>;
  schemaType?: 'localBusiness' | 'none';
  variant?: 'default' | 'home' | 'bare';
  active?: 'home' | 'dive-sites' | 'courses' | 'plan' | 'about' | 'contact' | null;
}

const {
  title,
  description,
  locale = 'en',
  image,
  noindex,
  alternates,
  schemaType = 'localBusiness',
  variant = 'default',
  active = null,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&family=IBM+Plex+Sans:ital,wght@0,300..700;1,400..500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      locale={locale}
      image={image}
      noindex={noindex}
      alternates={alternates}
    />
    {schemaType === 'localBusiness' && <Schema type="localBusiness" />}
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    {variant === 'home' && <HomeHeader locale={locale} />}
    {variant === 'default' && <SiteHeader locale={locale} active={active} />}
    <main id="main">
      <slot />
    </main>
    <SiteFooter locale={locale} />
  </body>
</html>
