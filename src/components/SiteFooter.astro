---
import Container from '@/components/ui/Container.astro';
import { SITE, type Locale } from '@/lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-[var(--spacing-section)]">
  <Container size="wide" as="div" class="py-10 grid gap-8 md:grid-cols-4">
    <section>
      <h2 class="font-semibold mb-2">{SITE.shortName}</h2>
      <p class="text-sm text-[var(--color-ink-muted)]">{SITE.tagline}</p>
    </section>

    <section>
      <h2 class="font-semibold mb-2">{locale === 'hr' ? 'Kontakt' : 'Contact'}</h2>
      <address class="not-italic text-sm space-y-1">
        <div><a href={`mailto:${SITE.email}`} class="hover:underline">{SITE.email}</a></div>
        {SITE.phones.map((p) => (
          <div><a href={`tel:${p.replace(/\s+/g, '')}`} class="hover:underline">{p}</a></div>
        ))}
      </address>
    </section>

    <section>
      <h2 class="font-semibold mb-2">{locale === 'hr' ? 'Adresa' : 'Address'}</h2>
      <address class="not-italic text-sm text-[var(--color-ink-muted)]">
        {SITE.address.street}<br />
        {SITE.address.postal} {SITE.address.city}<br />
        {SITE.address.country}
      </address>
    </section>

    <section>
      <h2 class="font-semibold mb-2">{locale === 'hr' ? 'Pratite nas' : 'Follow'}</h2>
      <ul class="flex gap-4 text-sm">
        <li><a href={SITE.social.facebook} rel="me noopener" target="_blank" class="hover:underline">Facebook</a></li>
        <li><a href={SITE.social.instagram} rel="me noopener" target="_blank" class="hover:underline">Instagram</a></li>
      </ul>
    </section>
  </Container>

  <Container size="wide" as="div" class="py-4 border-t border-[var(--color-border)] text-xs text-[var(--color-ink-muted)] flex flex-wrap justify-between gap-2">
    <span>© {year} {SITE.name}</span>
    <span>Preview build</span>
  </Container>
</footer>
