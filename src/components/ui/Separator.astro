---
import { cn } from '@/lib/utils';

interface Props {
  orientation?: 'horizontal' | 'vertical';
  class?: string;
}

const { orientation = 'horizontal', class: className } = Astro.props;

const base = 'shrink-0 bg-[var(--color-border)]';
const sizeClass = orientation === 'horizontal' ? 'h-px w-full' : 'w-px h-full';
---

<div role="separator" aria-orientation={orientation} class={cn(base, sizeClass, className)}></div>
