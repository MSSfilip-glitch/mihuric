---
import { cn } from '@/lib/utils';

type Variant = 'default' | 'outline' | 'muted';

interface Props {
  variant?: Variant;
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const base =
  'inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full';

const variantClasses: Record<Variant, string> = {
  default: 'bg-[var(--color-brand)] text-[var(--color-brand-foreground)]',
  outline: 'border border-[var(--color-border)] text-[var(--color-ink)]',
  muted:   'bg-[var(--color-surface-muted)] text-[var(--color-ink-muted)]',
};
---

<span class={cn(base, variantClasses[variant], className)}>
  <slot />
</span>
